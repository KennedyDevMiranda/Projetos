            {
                if (!decimal.TryParse(txtValor.Text, NumberStyles.Any, _ptBR, out decimal valor) || valor <= 0)
                { MessageBox.Show("Valor inválido."); frm.DialogResult = DialogResult.None; return; }

                frm.Tag = (valor, cmbForma.SelectedItem!.ToString()!, txtObs.Text.Trim().Length > 0 ? txtObs.Text.Trim() : (string?)null);
            };

            return frm;
        }

