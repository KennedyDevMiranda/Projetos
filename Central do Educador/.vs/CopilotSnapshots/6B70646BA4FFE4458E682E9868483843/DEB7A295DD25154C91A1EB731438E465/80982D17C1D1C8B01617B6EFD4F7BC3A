        private async void btnExecutarNotif_Click(object sender, EventArgs e)
        {
            btnExecutarNotif.Enabled = false;
            txtResultado.Clear();
            txtResultado.AppendText($"[{DateTime.Now:HH:mm:ss}] Iniciando processamento...\r\n");

            try
            {
                var r = await NotificacaoFinanceiraService.ProcessarAsync();
                txtResultado.AppendText($"[{DateTime.Now:HH:mm:ss}] Concluído!\r\n");
                txtResultado.AppendText($"  📋 Lembretes gerados: {r.LembretesGerados}\r\n");
                txtResultado.AppendText($"  ⚠️ Cobranças geradas: {r.CobrancasGeradas}\r\n");
                txtResultado.AppendText($"  📧 E-mails: {r.EmailsEnviados} enviados, {r.EmailsFalhas} falhas\r\n");
                txtResultado.AppendText($"  📱 WhatsApp: {r.WhatsAppEnviados} enviados, {r.WhatsAppFalhas} falhas");
                if (r.WhatsAppLinks > 0)
                    txtResultado.AppendText($", {r.WhatsAppLinks} links abertos");
                txtResultado.AppendText("\r\n");

                foreach (var erro in r.Erros)
                    txtResultado.AppendText($"  ❌ {erro}\r\n");

                await CarregarDashboardAsync();
            }
            catch (Exception ex)
            {
                txtResultado.AppendText($"  ❌ Erro: {ex.Message}\r\n");
            }
            finally
            {
                btnExecutarNotif.Enabled = true;
            }
        }

