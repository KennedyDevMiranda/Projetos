        private void btnFiltro_Click(object sender, EventArgs e)
        {
            try
            {
                // 1) Verificações de segurança
                if (panelFiltro == null) return;
                if (btnFiltro == null)
                {
                    // Apenas alterna visibilidade se o botão não existir por algum motivo
                    panelFiltro.Visible = !panelFiltro.Visible;
                    return;
                }

                // 2) Alterna entre oculto e visível, salvando/restaurando altura para comportamento "recolhido"
                if (panelFiltro.Visible)
                {
                    // salva a altura atual para restaurar depois
                    panelFiltro.Tag = panelFiltro.Height;
                    panelFiltro.Visible = false;
                    btnFiltro.Text = "Mostrar Filtro";
                }
                else
                {
                    // restaura altura se estiver armazenada
                    if (panelFiltro.Tag is int h && h > 0)
                        panelFiltro.Height = h;

                    panelFiltro.Visible = true;
                    btnFiltro.Text = "Ocultar Filtro";
                }
            }
            catch (Exception ex)
            {
                // Em caso de erro, apenas mostra mensagem e não impede a aplicação
                MessageBox.Show($"Erro ao alternar filtro: {ex.Message}", "Erro", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void dgvMain_ColumnHeaderMouseClick(object? sender, DataGridViewCellMouseEventArgs e)
        {
            var col = dgvMain.Columns[e.ColumnIndex];
            if (col == null) return;

            // Nome da propriedade do objeto (RegistroTaxa) quando DataSource é List<RegistroTaxa>
            var prop = col.DataPropertyName;

            // Se for coluna “solta” sem DataPropertyName, tenta usar o Name
            if (string.IsNullOrWhiteSpace(prop))
                prop = col.Name;

            if (string.IsNullOrWhiteSpace(prop))
                return;

            // Alterna ASC/DESC quando clica na mesma coluna
            if (_sortCol == prop) _sortAsc = !_sortAsc;
            else { _sortCol = prop; _sortAsc = true; }

            OrdenarGridPor(prop, _sortAsc);
            AplicarSetinhaOrdenacao(col, _sortAsc);
        }

        private void OrdenarGridPor(string propriedade, bool asc)
        {
            if (dgvMain.DataSource is not List<RegistroTaxa> lista)
                return;

            // Ordena por reflection (simples e funciona pra qualquer propriedade)
            Func<RegistroTaxa, object?> key = r =>
                r.GetType().GetProperty(propriedade)?.GetValue(r, null);

            var ordenada = asc
                ? lista.OrderBy(key).ToList()
                : lista.OrderByDescending(key).ToList();

            dgvMain.DataSource = null;
            dgvMain.DataSource = ordenada;
        }

        private void AplicarSetinhaOrdenacao(DataGridViewColumn colClicada, bool asc)
        {
            // Verifica se o grid ou a coluna são nulos (evita avisos de nulidade)
            if (dgvMain == null)
                return;

            // limpa setinhas antigas
            foreach (DataGridViewColumn c in dgvMain.Columns)
                c.HeaderCell?.SortGlyphDirection = SortOrder.None;

            colClicada.HeaderCell?.SortGlyphDirection = asc ? SortOrder.Ascending : SortOrder.Descending;
        }

