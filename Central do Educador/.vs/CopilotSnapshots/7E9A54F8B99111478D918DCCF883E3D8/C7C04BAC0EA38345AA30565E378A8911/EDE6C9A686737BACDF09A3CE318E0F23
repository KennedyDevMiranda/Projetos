            _tAtualiza.Interval = 250; // 0,25s (parece instantâneo)
            _tAtualiza.Tick += (s, e) =>
            {
                _tAtualiza.Stop();
                AtualizarGrid();
            };

            // liga os eventos
            dtpDe.ValueChanged += (_, __) => AgendarAtualizacao();
            dtpAte.ValueChanged += (_, __) => AgendarAtualizacao();

            // opcional: quando fecha o calendário
            dtpDe.CloseUp += (_, __) => AgendarAtualizacao();
            dtpAte.CloseUp += (_, __) => AgendarAtualizacao();
        }

        private void AgendarAtualizacao()
        {
            _tAtualiza.Stop();
            _tAtualiza.Start();
        }

        private void Principal_Load(object sender, EventArgs e)
        {
            CarregarConfiguracoes();

            SetarPeriodoPadrao();

            AtualizarGrid();

            // 3) Carrega o grid ao abrir.
            CarregarGrid();

            dgvMain.ColumnHeaderMouseClick += dgvMain_ColumnHeaderMouseClick;
        }

        private void AtualizarGrid()
        {
            var de = dtpDe.Value.Date;
            var ate = dtpAte.Value.Date;
            var alunoLike = txtFiltroAluno.Text?.Trim() ?? "";

            bool? lancado = chkSomenteLancados.Checked ? true : (bool?)null;
            // null = todos, true = só lançados

            var lista = _repo.GetFiltered(de, ate, alunoLike, lancado);

            dgvMain.DataSource = lista;
            CustomizarGrid(dgvMain);

            // se já tinha uma ordenação escolhida, reaplica
            if (!string.IsNullOrWhiteSpace(_sortCol))
            {
                OrdenarGridPor(_sortCol, _sortAsc);

                // tenta recolocar a setinha na coluna certa
                var col = dgvMain.Columns
                    .Cast<DataGridViewColumn>()
                    .FirstOrDefault(c => c.DataPropertyName == _sortCol || c.Name == _sortCol);

                if (col != null) AplicarSetinhaOrdenacao(col, _sortAsc);
            }
        }

        private void CarregarConfiguracoes()
        {
