        private void btnExcluir_Click(object sender, EventArgs e)
        {
            try
            {
                if (dgvMain.CurrentRow == null)
                {
                    MessageBox.Show("Selecione um registro para excluir.");
                    return;
                }

                // Quando está bindado em lista de objetos
                if (dgvMain.CurrentRow.DataBoundItem is not RegistroTaxa item)
                {
                    MessageBox.Show("Não foi possível identificar o registro selecionado.");
                    return;
                }

                var resp = MessageBox.Show(
                    $"Deseja realmente excluir o registro Id {item.Id} do aluno '{item.NomeAluno}'?",
                    "Confirmar exclusão",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Warning);

                if (resp != DialogResult.Yes) return;

                // Se você usa service:
                _service.Delete(item.Id);

                // ou se usa repo direto:
                // _repo.Delete(item.Id);

                AtualizarGrid(); // recarrega do banco
                MessageBox.Show("Registro excluído com sucesso!");
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message, "Erro", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

