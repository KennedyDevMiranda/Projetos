            if (dgvMain == null || dgvMain.Columns.Count == 0)
                return;

            dgvMain.SelectionMode = DataGridViewSelectionMode.FullRowSelect;
            dgvMain.MultiSelect = false;
            dgvMain.ReadOnly = true;
            dgvMain.AllowUserToAddRows = false;
            dgvMain.AllowUserToDeleteRows = false;
            dgvMain.AllowUserToResizeRows = false;
            dgvMain.RowHeadersVisible = false;

            void Hide(string col)
            {
                if (dgvMain.Columns.Contains(col))
                    dgvMain.Columns[col].Visible = false;
            }

            void Header(string col, string text)
            {
                if (dgvMain.Columns.Contains(col))
                    dgvMain.Columns[col].HeaderText = text;
            }

            void Width(string col, int w)
            {
                if (dgvMain.Columns.Contains(col))
                    dgvMain.Columns[col].Width = w;
            }

            void FormatDate(string col)
            {
                if (dgvMain.Columns.Contains(col))
                    dgvMain.Columns[col].DefaultCellStyle.Format = "dd/MM/yyyy";
            }

            void AlignCenter(string col)
            {
                if (dgvMain.Columns.Contains(col))
                    dgvMain.Columns[col].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleCenter;
            }

            // Ocultar colunas internas
            Hide("AlunoId");
            Hide("UsuarioId");

            // Títulos
            Header("Id", "Id");
            Header("NomeAluno", "Nome do Aluno");
            Header("NomeUsuario", "Usuário");
            Header("DataFalta", "Data da Falta");
            Header("DataRegistro", "Data do Registro");
            Header("DataReposicao", "Data de Reposição");
            Header("Quantidade", "Qtd. de Falta");
            Header("Lancado", "Lançado");
            Header("NaoAgendado", "Não agendado");
            Header("Historico", "Histórico");
            Header("Observacao", "Observação");

            // Formato de data
            FormatDate("DataFalta");
            FormatDate("DataRegistro");
            FormatDate("DataReposicao");

            // Larguras
            Width("Id", 60);
            Width("NomeAluno", 260);
            Width("NomeUsuario", 120);
            Width("DataFalta", 110);
            Width("DataRegistro", 120);
            Width("DataReposicao", 130);
            Width("Quantidade", 100);
            Width("Lancado", 70);
            Width("NaoAgendado", 110);
            Width("Historico", 80);
            Width("Observacao", 240);

            // Alinhamentos
            AlignCenter("Id");
            AlignCenter("DataFalta");
            AlignCenter("DataRegistro");
            AlignCenter("DataReposicao");
            AlignCenter("Quantidade");
            AlignCenter("Lancado");
            AlignCenter("NaoAgendado");
            AlignCenter("Historico");

            // Ordem
            int idx = 0;
            void Order(string col)
            {
                if (dgvMain.Columns.Contains(col))
                    dgvMain.Columns[col].DisplayIndex = idx++;
            }

            Order("Id");
            Order("NomeAluno");
            Order("DataFalta");
            Order("DataRegistro");
            Order("DataReposicao");
            Order("Quantidade");
            Order("Lancado");
            Order("NaoAgendado");
            Order("Historico");
            Order("NomeUsuario");
            Order("Observacao");

            if (dgvMain.Columns.Contains("Observacao"))
                dgvMain.Columns["Observacao"].AutoSizeMode = DataGridViewAutoSizeColumnMode.Fill;
        }

        private void CustomizarGrid(DataGridView dgv)
        {
            dgv.AllowUserToAddRows = false;
            dgv.AllowUserToDeleteRows = false;
            dgv.ReadOnly = true;
            dgv.MultiSelect = false;
            dgv.SelectionMode = DataGridViewSelectionMode.FullRowSelect;
            dgv.RowHeadersVisible = false;
            dgv.AutoGenerateColumns = true;

            // Cabeçalho (estilo + altura)
            dgv.EnableHeadersVisualStyles = false;
            dgv.ColumnHeadersHeightSizeMode = DataGridViewColumnHeadersHeightSizeMode.DisableResizing;
            dgv.ColumnHeadersHeight = 36;

            dgv.ColumnHeadersDefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleLeft;
            dgv.ColumnHeadersDefaultCellStyle.Font = new Font("Century Gothic", 9, FontStyle.Bold);
            dgv.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(30, 30, 30);
            dgv.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;

            // Linhas
            dgv.DefaultCellStyle.Font = new Font("Century Gothic", 9, FontStyle.Regular);
            dgv.DefaultCellStyle.SelectionBackColor = Color.FromArgb(220, 230, 255);
            dgv.DefaultCellStyle.SelectionForeColor = Color.Black;
            dgv.AlternatingRowsDefaultCellStyle.BackColor = Color.FromArgb(245, 245, 245);

            dgv.AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill;
            dgv.AutoSizeRowsMode = DataGridViewAutoSizeRowsMode.None;
        }

        private void AtualizarRodapeTotais(List<RegistroTaxa> lista)
        {
            lista ??= new List<RegistroTaxa>();

            var qtdTotal = lista.Sum(x => Math.Max(0, x.Quantidade));

            var valorTaxa = _config?.ValorTaxaPadrao ?? 0m;
            var percComissao = _config?.PercentualComissao ?? 0m;

            var total = qtdTotal * valorTaxa;
            var comissao = total * (percComissao / 100m);

            total = Math.Round(total, 2, MidpointRounding.AwayFromZero);
            comissao = Math.Round(comissao, 2, MidpointRounding.AwayFromZero);

            if (lblTotalRegistros != null)
                lblTotalRegistros.Text = $"Total registros: {lista.Count}";

            if (lblTotalFaltas != null)
                lblTotalFaltas.Text = $"Qtd. faltas: {qtdTotal}";

            if (lblTotal != null)
                lblTotal.Text = $"Total: R$ {total:N2}";

            if (lblComissao != null)
                lblComissao.Text = $"Comissão: R$ {comissao:N2}";
        }

