        // ---------------- GRID (READ) ----------------
        private void CarregarGrid()
        {
            if (dgvMain == null) return;

            var de = dtpDe?.Value.Date ?? DateTime.Today.AddMonths(-1);
            var ate = dtpAte?.Value.Date ?? DateTime.Today;
            var alunoLike = txtFiltroAluno?.Text?.Trim() ?? "";

            // Adicione o argumento 'lancado' como string
            string lancado = chkSomenteLancados.Checked ? "true" : "false";

            var lista = _service.Listar(de, ate, alunoLike, lancado);

            dgvMain.DataSource = null;
            dgvMain.AutoGenerateColumns = true;
            dgvMain.DataSource = lista;

            AjustarColunasGrid();
            AtualizarRodapeTotais(lista);
        }

        private void AjustarColunasGrid()
