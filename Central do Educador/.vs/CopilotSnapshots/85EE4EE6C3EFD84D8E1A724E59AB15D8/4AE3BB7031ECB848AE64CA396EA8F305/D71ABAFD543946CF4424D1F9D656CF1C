        private void FormatarGridEntregaLivros()
        {
            var g = dgvEntregas;
            if (g == null || g.Columns == null) return;

            // comportamento/visual
            g.AllowUserToAddRows = false;
            g.AllowUserToDeleteRows = false;
            g.AllowUserToResizeRows = false;
            g.ReadOnly = true;
            g.MultiSelect = false;
            g.SelectionMode = DataGridViewSelectionMode.FullRowSelect;

            g.AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill;
            g.RowHeadersVisible = false;

            g.EnableHeadersVisualStyles = false;
            g.ColumnHeadersHeightSizeMode = DataGridViewColumnHeadersHeightSizeMode.DisableResizing;
            g.ColumnHeadersHeight = 32;

            // zebra
            g.AlternatingRowsDefaultCellStyle.BackColor = System.Drawing.Color.FromArgb(245, 245, 245);

            // fonte
            g.DefaultCellStyle.Font = new System.Drawing.Font("Century Gothic", 10F);
            g.ColumnHeadersDefaultCellStyle.Font = new System.Drawing.Font("Century Gothic", 9F, System.Drawing.FontStyle.Bold);

            // ====== colunas (headers + alinhamento + largura mínima) ======
            AjustarColunaTexto(g, "Aluno", "Aluno", 220, DataGridViewContentAlignment.MiddleLeft);
            AjustarColunaTexto(g, "Materia", "Matéria", 160, DataGridViewContentAlignment.MiddleLeft);

            AjustarColunaNumero(g, "AulasConcluidas", "Aulas Concluídas", 70);

            AjustarColunaTexto(g, "DiasAgendamento", "Dias", 90, DataGridViewContentAlignment.MiddleCenter);
            AjustarColunaTexto(g, "HorasAgendamento", "Horas", 90, DataGridViewContentAlignment.MiddleCenter);

            AjustarColunaTexto(g, "ProximaMateria", "Próx. Matéria", 170, DataGridViewContentAlignment.MiddleLeft);
            AjustarColunaTexto(g, "Apostila", "Apostila", 120, DataGridViewContentAlignment.MiddleLeft);

            AjustarColunaTexto(g, "EntregaFisica", "Entrega Física", 110, DataGridViewContentAlignment.MiddleCenter);

            // Quebra linha em campos mais longos (opcional)
            if (g.Columns.Contains("ProximaMateria"))
                g.Columns["ProximaMateria"]!.DefaultCellStyle.WrapMode = DataGridViewTriState.True;

            if (g.Columns.Contains("Apostila"))
                g.Columns["Apostila"]!.DefaultCellStyle.WrapMode = DataGridViewTriState.True;

            g.AutoSizeRowsMode = DataGridViewAutoSizeRowsMode.DisplayedCells;

            // Centralizações (reforço)
            CentralizarSeExistir(g, "AulasConcluidas");
            CentralizarSeExistir(g, "DiasAgendamento");
            CentralizarSeExistir(g, "HorasAgendamento");
            CentralizarSeExistir(g, "EntregaFisica");

            // Formata: EntregaFisica (S/N) -> (Sim/Não) e destaca pendência
            g.CellFormatting -= dgvEntregas_CellFormatting;
            g.CellFormatting += dgvEntregas_CellFormatting;

            // (opcional) destaque por linha: pendente em vermelho
            DestacarPendenciasEntrega();
        }

