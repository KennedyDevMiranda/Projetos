        private DataTable LerExcelParaDataTable(string caminho)
        {
            using var stream = File.Open(caminho, FileMode.Open, FileAccess.Read, FileShare.ReadWrite);
            using var reader = ExcelReaderFactory.CreateReader(stream);

            var dt = new DataTable();
            dt.Columns.Add("Aluno");
            dt.Columns.Add("Materia");
            dt.Columns.Add("AulasConcluidas");
            dt.Columns.Add("DiasAgendamento");
            dt.Columns.Add("HorasAgendamento");
            dt.Columns.Add("ProximaMateria");
            dt.Columns.Add("Apostila");
            dt.Columns.Add("EntregaFisica");

            // O Excel NÃO possui linha de cabeçalho — todas as linhas são dados.
            // Colunas fixas: A=Aluno, B=Matéria, C=Aulas, D=Dias, E=Horas,
            //                F=PróximaMatéria, G=Apostila, H=EntregaFísica
            bool primeiraLinha = true;

            while (reader.Read())
            {
                string aluno = reader.GetValue(0)?.ToString()?.Trim() ?? "";
                string materia = reader.GetValue(1)?.ToString()?.Trim() ?? "";
                string aulas = reader.GetValue(2)?.ToString()?.Trim() ?? "";
                string dias = reader.GetValue(3)?.ToString()?.Trim() ?? "";
                string horas = reader.GetValue(4)?.ToString()?.Trim() ?? "";
                string proximaMateria = reader.GetValue(5)?.ToString()?.Trim() ?? "";
                string apostila = reader.GetValue(6)?.ToString()?.Trim() ?? "";
                string entrega = reader.GetValue(7)?.ToString()?.Trim().ToUpper() ?? "N";

                if (string.IsNullOrWhiteSpace(aluno)) continue;

                // === Verificação na primeira linha de dados ===
                if (primeiraLinha)
                {
                    primeiraLinha = false;

                    var sb = new StringBuilder();
                    sb.AppendLine("Verifique se os dados estão na coluna correta:\n");
                    sb.AppendLine($"  Aluno:            \"{Truncar(aluno, 40)}\"");
                    sb.AppendLine($"  Matéria:           \"{Truncar(materia, 40)}\"");
                    sb.AppendLine($"  Aulas Concluídas:  \"{aulas}\"");
                    sb.AppendLine($"  Dias Agendamento:  \"{Truncar(dias, 30)}\"");
                    sb.AppendLine($"  Horas Agendamento: \"{Truncar(horas, 30)}\"");
                    sb.AppendLine($"  Próx. Matéria:     \"{Truncar(proximaMateria, 40)}\"");
                    sb.AppendLine($"  Apostila:          \"{Truncar(apostila, 40)}\"");
                    sb.AppendLine($"  Entrega Física:    \"{entrega}\"");
                    sb.AppendLine();
                    sb.AppendLine("Os dados estão corretos?");

                    var resultado = MessageBox.Show(
                        sb.ToString(),
                        "Verificação de Colunas",
                        MessageBoxButtons.YesNo,
                        MessageBoxIcon.Question);

                    if (resultado == DialogResult.No)
                    {
                        MessageBox.Show(
                            "Importação cancelada.\n\n" +
                            "O arquivo Excel precisa ter as colunas nesta ordem:\n" +
                            "  A = Aluno (nome)\n" +
                            "  B = Matéria\n" +
                            "  C = Aulas Concluídas (número)\n" +
                            "  D = Dias de Agendamento\n" +
                            "  E = Horas de Agendamento\n" +
                            "  F = Próxima Matéria\n" +
                            "  G = Apostila\n" +
                            "  H = Entrega Física (S/N)",
                            "Importação Cancelada",
                            MessageBoxButtons.OK,
                            MessageBoxIcon.Warning);

                        return dt; // retorna DataTable vazio
                    }
                }

                entrega = entrega == "S" || entrega == "SIM" ? "S" : "N";

                dt.Rows.Add(aluno, materia, aulas, dias, horas, proximaMateria, apostila, entrega);
            }

            return dt;
        }

        /// <summary>
        /// Trunca um texto para exibição em diagnósticos.
        /// </summary>
        private static string Truncar(string texto, int maxLength)
        {
            if (string.IsNullOrEmpty(texto)) return "";
            return texto.Length <= maxLength ? texto : texto[..maxLength] + "...";
        }

        private DataTable LerCsvParaDataTable(string caminho)
        {
            var dt = new DataTable();
            dt.Columns.Add("Aluno");
            dt.Columns.Add("Materia");
            dt.Columns.Add("AulasConcluidas");
            dt.Columns.Add("EntregaFisica");

            var linhas = File.ReadAllLines(caminho, Encoding.GetEncoding(1252));
            if (linhas.Length == 0) return dt;

            char sep = linhas[0].Contains(';') ? ';' : ',';

            foreach (var linha in linhas.Skip(1))
            {
                if (string.IsNullOrWhiteSpace(linha)) continue;

                var dados = linha.Split(sep);
                if (dados.Length < 4) continue;

                string aluno = dados[0].Trim();
                string materia = dados[1].Trim();
                string aulas = dados[2].Trim();
                string entrega = (dados[3] ?? "N").Trim().ToUpper();

                if (string.IsNullOrWhiteSpace(aluno)) continue;

                entrega = entrega == "S" || entrega == "SIM" ? "S" : "N";

                dt.Rows.Add(aluno, materia, aulas, entrega);
            }

            return dt;
        }

        private void btnImportar_Click(object sender, EventArgs e)
        {
            using var ofd = new OpenFileDialog
            {
                Filter = "Arquivos Suportados (*.xls, *.xlsx, *.csv)|*.xls;*.xlsx;*.csv"
            };

            if (ofd.ShowDialog() != DialogResult.OK) return;

            try
            {
                string ext = Path.GetExtension(ofd.FileName).ToLower();

                _dtPreview = (ext == ".csv")
                    ? LerCsvParaDataTable(ofd.FileName)
                    : LerExcelParaDataTable(ofd.FileName);

                if (dgvEntregas != null && _dtPreview != null)
                {
                    dgvEntregas.DataSource = _dtPreview;

                    if (lblEmissao != null)
                        lblEmissao.Text = $"Importado em: {DateTime.Now:dd/MM/yyyy HH:mm:ss}";

                    MessageBox.Show($"Prévia carregada: {_dtPreview.Rows.Count} linhas.\nAgora clique em Confirmar para gravar no banco.");
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Erro ao importar: " + ex.Message);
            }
        }

        private void btnConfirmarImportacao_Click(object sender, EventArgs e)
        {
            if (_dtPreview == null || _dtPreview.Rows.Count == 0)
            {
                MessageBox.Show("Nenhuma prévia carregada.");
                return;
            }

            try
            {
                using var conn = new SqliteConnection(connString);
                conn.Open();

                using var tx = conn.BeginTransaction();

                foreach (DataRow row in _dtPreview.Rows)
                {
                    string aluno = row["Aluno"]?.ToString() ?? "";
                    string materia = row["Materia"]?.ToString() ?? "";
                    string aulas = row["AulasConcluidas"]?.ToString() ?? "";
                    string dias = (row.Table?.Columns.Contains("DiasAgendamento") == true) ? row["DiasAgendamento"]?.ToString() ?? "" : "";
                    string horas = (row.Table?.Columns.Contains("HorasAgendamento") == true) ? row["HorasAgendamento"]?.ToString() ?? "" : "";
                    string proximaMateria = (row.Table?.Columns.Contains("ProximaMateria") == true) ? row["ProximaMateria"]?.ToString() ?? "" : "";
                    string apostila = (row.Table?.Columns.Contains("Apostila") == true) ? row["Apostila"]?.ToString() ?? "" : "";
                    string entrega = row["EntregaFisica"]?.ToString() ?? "N";

                    if (string.IsNullOrWhiteSpace(aluno)) continue;

                    SalvarNoBanco(aluno, materia, aulas, dias, horas, proximaMateria, apostila, entrega, conn, tx);
                }

                tx.Commit();

                if (lblEmissao != null)
                    lblEmissao.Text = $"Última importação: {DateTime.Now:dd/MM/yyyy HH:mm:ss}";

                MessageBox.Show("Importação gravada no banco com sucesso!");
                CarregarHorariosNoFiltro();
                AtualizarGrid();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Erro ao gravar no banco: " + ex.Message);
            }
        }

