        private void CarregarHorariosNoFiltro()
        {
            if (cmbHorario == null) return;

            cmbHorario.Items.Clear();
            cmbHorario.Items.Add("Todos");

            try
            {
                using var conn = new SqliteConnection(connString);
                conn.Open();

                using var cmd = new SqliteCommand(
                    @"SELECT DISTINCT HorasAgendamento 
                      FROM EntregaLivros 
                      WHERE HorasAgendamento IS NOT NULL AND TRIM(HorasAgendamento) != ''
                      ORDER BY HorasAgendamento", conn);

                using var reader = cmd.ExecuteReader();
                while (reader.Read())
                {
                    string horario = reader.GetString(0).Trim();
                    if (!string.IsNullOrWhiteSpace(horario))
                        cmbHorario.Items.Add(horario);
                }
            }
            catch
            {
                // Se falhar, mantém apenas "Todos"
            }

            cmbHorario.SelectedIndex = 0;
        }

