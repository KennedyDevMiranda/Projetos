        private void SalvarNoBanco(string aluno, string materia, string aulas, string dias, string horas, string proximaMateria, string apostila, string entrega, SqliteConnection conn, SqliteTransaction tx)
        {
            // Tenta atualizar primeiro, se não existir, insere
            string sqlUpdate = @"
                UPDATE EntregaLivros 
                SET Materia = @materia, 
                    AulasConcluidas = @aulas, 
                    DiasAgendamento = @dias,
                    HorasAgendamento = @horas,
                    ProximaMateria = @proximaMateria,
                    Apostila = @apostila,
                    EntregaFisica = @entrega
                WHERE Aluno = @aluno";

            using (var cmdUpdate = new SqliteCommand(sqlUpdate, conn, tx))
            {
                cmdUpdate.Parameters.AddWithValue("@aluno", aluno);
                cmdUpdate.Parameters.AddWithValue("@materia", materia);
                cmdUpdate.Parameters.AddWithValue("@aulas", aulas);
                cmdUpdate.Parameters.AddWithValue("@dias", dias);
                cmdUpdate.Parameters.AddWithValue("@horas", horas);
                cmdUpdate.Parameters.AddWithValue("@proximaMateria", proximaMateria);
                cmdUpdate.Parameters.AddWithValue("@apostila", apostila);
                cmdUpdate.Parameters.AddWithValue("@entrega", entrega);

                int rowsAffected = cmdUpdate.ExecuteNonQuery();

                // Se não atualizou nenhuma linha, insere
                if (rowsAffected == 0)
                {
                    string sqlInsert = @"
                        INSERT INTO EntregaLivros (Aluno, Materia, AulasConcluidas, DiasAgendamento, HorasAgendamento, ProximaMateria, Apostila, EntregaFisica)
                        VALUES (@aluno, @materia, @aulas, @dias, @horas, @proximaMateria, @apostila, @entrega)";

                    using (var cmdInsert = new SqliteCommand(sqlInsert, conn, tx))
                    {
                        cmdInsert.Parameters.AddWithValue("@aluno", aluno);
                        cmdInsert.Parameters.AddWithValue("@materia", materia);
                        cmdInsert.Parameters.AddWithValue("@aulas", aulas);
                        cmdInsert.Parameters.AddWithValue("@dias", dias);
                        cmdInsert.Parameters.AddWithValue("@horas", horas);
                        cmdInsert.Parameters.AddWithValue("@proximaMateria", proximaMateria);
                        cmdInsert.Parameters.AddWithValue("@apostila", apostila);
                        cmdInsert.Parameters.AddWithValue("@entrega", entrega);
                        cmdInsert.ExecuteNonQuery();
                    }
                }
            }
        }

        private void AtualizarGrid()
        {
            if (!_loaded || dgvEntregas == null) return;

            string filtroEntrega = "Todos";
            if (rdbSim != null && rdbSim.Checked)
                filtroEntrega = "Sim";
            else if (rdbNao != null && rdbNao.Checked)
                filtroEntrega = "Não";

            string pesquisa = (cmbPesquisaAluno?.Text ?? "").Trim();
            string diaSemana = cmbDiaSemana?.SelectedItem?.ToString() ?? "Todos";

            try
            {
                using var conn = new SqliteConnection(connString);
                conn.Open();

                string sql = @"
                    SELECT Aluno, Materia, AulasConcluidas, 
                           DiasAgendamento, HorasAgendamento, 
                           ProximaMateria, Apostila, EntregaFisica
                    FROM EntregaLivros
                    WHERE 1=1";

                if (filtroEntrega == "Sim")
                    sql += " AND EntregaFisica = 'S'";
                else if (filtroEntrega == "Não")
                    sql += " AND EntregaFisica = 'N'";

                if (!string.IsNullOrWhiteSpace(pesquisa))
                    sql += " AND Aluno LIKE @pesquisa ESCAPE '\\'";

                if (!string.IsNullOrWhiteSpace(diaSemana) && diaSemana != "Todos")
                    sql += " AND DiasAgendamento LIKE @diaSemana ESCAPE '\\'";

                sql += " ORDER BY EntregaFisica ASC, Aluno ASC";

                using var cmd = new SqliteCommand(sql, conn);

                if (!string.IsNullOrWhiteSpace(pesquisa))
                {
                    string pesquisaEscapada = pesquisa
                        .Replace("\\", "\\\\")
                        .Replace("%", "\\%")
                        .Replace("_", "\\_");
                    cmd.Parameters.AddWithValue("@pesquisa", $"%{pesquisaEscapada}%");
                }

                if (!string.IsNullOrWhiteSpace(diaSemana) && diaSemana != "Todos")
                {
                    string diaEscapado = diaSemana
                        .Replace("\\", "\\\\")
                        .Replace("%", "\\%")
                        .Replace("_", "\\_");
                    cmd.Parameters.AddWithValue("@diaSemana", $"%{diaEscapado}%");
                }

                var dt = new DataTable();
                using (var reader = cmd.ExecuteReader())
                {
                    dt.Load(reader);
                }

                dgvEntregas.DataSource = dt;

                // Atualiza a label com o total de registros
                lblTotal.Text = $"Total de registros: {dt.Rows.Count}";

                if (dt.Rows.Count > 0)
                    FormatarGridEntregaLivros();
            }
            catch (Exception ex)
            {
                MessageBox.Show("Erro ao atualizar grid: " + ex.Message);
            }
        }

