        private void AjustarColunaTexto(DataGridView g, string nome, string header, int minWidth, DataGridViewContentAlignment alignment)
        {
            if (!g.Columns.Contains(nome)) return;
            g.Columns[nome].HeaderText = header;
            g.Columns[nome].MinimumWidth = minWidth;
            g.Columns[nome].DefaultCellStyle.Alignment = alignment;
        }

        private void AjustarColunaNumero(DataGridView g, string nome, string header, int minWidth)
        {
            if (!g.Columns.Contains(nome)) return;
            g.Columns[nome].HeaderText = header;
            g.Columns[nome].MinimumWidth = minWidth;
            g.Columns[nome].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleCenter;
        }

        private void CentralizarSeExistir(DataGridView g, string nomeColuna)
        {
            if (g.Columns.Contains(nomeColuna))
                g.Columns[nomeColuna].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleCenter;
        }

